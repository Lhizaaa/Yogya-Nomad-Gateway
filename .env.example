# Optional. Only needed if you want the Google Maps "Map View" with Places search.
# Without it, the app falls back to the free OpenStreetMap embed + static List View.
# Enable "Maps JavaScript API" + "Places API" in Google Cloud Console, then paste the key below.
VITE_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Backend (Vercel Serverless Functions di /api) — WAJIB diisi.
# Untuk dev lokal: salin baris di bawah ke file baru bernama ".env.local" lalu
# isi nilainya, jalankan dengan `vercel dev` (bukan `npm run dev`).
# Untuk produksi: isi via Vercel Dashboard → Project Settings → Environment Variables.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Connection string Supabase — pakai "Connection Pooling" (mode Transaction,
# port 6543), BUKAN "Direct connection" (port 5432), karena Serverless
# Functions butuh koneksi yang efisien untuk banyak invocation singkat.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=
