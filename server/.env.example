# Salin file ini menjadi ".env" lalu isi API key Anda.
# JANGAN commit file .env ke git — key harus tetap rahasia di server.

# API key dari https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port server proxy (frontend Vite akan proxy /api ke sini saat dev)
PORT=8787

# Model OpenAI. gpt-4o-mini = cepat & murah (default).
# Untuk kualitas lebih tinggi (lebih mahal): gpt-4o
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Konfigurasi PostgreSQL (READ-ONLY) untuk database yogya_nomad_db.
# Diatur manual via pgAdmin4. Isi DB_PASSWORD sesuai password user postgres Anda.
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=yogya_nomad_db
