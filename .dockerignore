# ============================================================================
# .dockerignore — Exclude files dari Docker build context
# Tujuan: Kurangi image size, faster build time, lebih aman
# ============================================================================

# Node
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log

# Git
.git
.gitignore
.gitattributes

# Environment (jangan include .env ke image)
.env
.env.local
.env.*.local
.env.backup

# Docker
Dockerfile
docker-compose.yml
.dockerignore
DOCKER.md

# Development
.vscode
.idea
.DS_Store
*.swp
*.swo
*~

# Build outputs
dist
dist-ssr
build
coverage

# Docs & config
README.md
LICENSE
.editorconfig

# OS
Thumbs.db
.AppleDouble
.LSOverride

# Backup files
*.backup
*.bak

# Logs
*.log
logs/

# Testing
.test/
cypress/
__tests__/

# IDE
.vscode/*
!.vscode/extensions.json
.idea/*
*.iml

# Frontend specific (tidak perlu di backend image)
src/
public/
package.json
vite.config.js
tailwind.config.js
